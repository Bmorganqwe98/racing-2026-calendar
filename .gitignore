# Cursor IDE workspace state (lives at workspace root via OneDrive sync;
# not part of the racing project's source code).
# Note: .cursor/rules/ IS tracked - that's where project rules live.
# Patterns are root-anchored with a leading "/" so they only match
# top-level folders, not similarly-named ones inside .cursor/.
/ai-tracking/
/argv.json
/browser-logs/
/extensions/
/ide_state.json
/mcp.backup.*.json
/mcp.json
/plans/
/plugins/
/projects/
/rules/
/skills/
/skills-cursor/
/subagents/
/commands/
*.plan.md

